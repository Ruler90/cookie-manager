{
  "name": "cookie-manager",
  "private": true,
  "version": "2.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build && node scripts/wrap-bookmarklet.mjs",
    "template": "vite build && node scripts/wrap-bookmarklet.mjs",
    "css": "sass src/styles/styles.scss src/styles/styles.css --no-source-map",
    "lint": "eslint . --ext .ts",
    "ts": "tsc --noEmit",
    "check": "npm run ts && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "sass": "^1.85.0",
    "terser": "^5.43.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
